{
    "name": "workspace-navigator",
    "version": "1.0.0",
    "description": "WhatsApp-based AI Assistant for Google Workspace",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node --require ./dns-preload.js dist/index.js",
        "dev": "node --require ./dns-preload.js --import tsx src/index.ts",
        "dev:watch": "nodemon --require ./dns-preload.js --exec 'node --loader tsx src/index.ts'"
    },
    "dependencies": {
        "@hapi/boom": "^10.0.1",
        "@types/qrcode": "^1.5.6",
        "@whiskeysockets/baileys": "^6.7.9",
        "bcryptjs": "^3.0.3",
        "chalk": "^4.1.2",
        "dotenv": "^16.4.7",
        "googleapis": "^144.0.0",
        "jsonwebtoken": "^9.0.3",
        "link-preview-js": "^3.2.0",
        "mongodb": "^7.1.0",
        "openai": "^6.18.0",
        "openclaw": "^2026.2.26",
        "pino": "^9.5.0",
        "qrcode": "^1.5.4",
        "qrcode-terminal": "^0.12.0",
        "socket.io": "^4.8.3",
        "uuid": "^11.0.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.10.0",
        "@types/uuid": "^10.0.0",
        "nodemon": "^3.1.9",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.7.0"
    }
}
