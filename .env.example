# ==========================================
# Workspace Navigator — Environment Variables
# Copy this file to .env and fill in real values
# ==========================================

# ──── REQUIRED: OpenAI ────────────────────
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4o
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo

# ──── REQUIRED: Google OAuth ──────────────
# Create credentials at: https://console.cloud.google.com/
# Type: Web Application
# Enable APIs: Gmail, Calendar, Drive, Sheets, Docs, Classroom
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ⚠️ UPDATE THIS when deploying to production:
# Local dev:  http://localhost:3000/oauth2callback
# Production: https://yourdomain.com/oauth2callback
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Token file path — used for local dev only (production uses Docker volumes)
GOOGLE_TOKEN_PATH=./data/tokens/google_tokens.json

# ──── REQUIRED: MongoDB ───────────────────
# Local dev (Docker Compose handles this):
MONGODB_URI=mongodb://localhost:27017
# Production (MongoDB Atlas free tier):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/workspace_navigator
MONGODB_DB_NAME=workspace_navigator

# ──── REQUIRED: Security Secrets ──────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET:       Signs 7-day user login tokens (dashboard auth)
# ENCRYPTION_KEY:   AES-256-GCM key for storing Manus/v0 API keys in MongoDB
JWT_SECRET=your-random-jwt-secret-min-32-chars-here
ENCRYPTION_KEY=your-random-encryption-key-min-32-chars-here

# ──── REQUIRED: E2B Cloud Sandbox ─────────
# Required for Cloud IDE / sandbox features
# Get your key at: https://e2b.dev/
E2B_API_KEY=your-e2b-api-key-here

# ──── OPTIONAL: WhatsApp ──────────────────
# ALLOWED_NUMBERS: comma-separated whitelist (empty = allow all)
ALLOWED_NUMBERS=
# OWNER_NUMBER: your main WhatsApp number (used for admin commands)
OWNER_NUMBER=919XXXXXXXXX

# Auth state path — used for local dev (production uses Docker volumes)
AUTH_STATE_PATH=./auth/baileys_auth

# ──── OPTIONAL: Memory / Storage ──────────
# Local SQLite path for MemOS memory (production uses Docker volume)
MEMORY_DB_PATH=./data/memory/navigator.db

# ──── OPTIONAL: Logging ───────────────────
# Options: trace, debug, info, warn, error, fatal
# Use 'warn' in production to reduce noise
LOG_LEVEL=info

# ──── OPTIONAL: External AI Tools ─────────
# Users can also add these from the Dashboard UI (stored encrypted in MongoDB)
MANUS_API_KEY=your-manus-api-key-here
V0_API_KEY=your-v0-api-key-here
